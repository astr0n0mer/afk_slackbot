FROM python:3.14-slim

ARG TEST_PYTHON=3.14
ENV TEST_PYTHON=${TEST_PYTHON}

WORKDIR /afk_slackbot

# Install system dependencies if needed
RUN apt update && apt install -y git && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip install uv

# Copy project files
COPY . /afk_slackbot

# Install all dependencies with uv (including dev dependencies)
RUN uv sync --all-extras --python "${TEST_PYTHON}"

# Run tests
CMD ["sh", "-c", "uv run --python \"$TEST_PYTHON\" python --version && uv run --python \"$TEST_PYTHON\" pytest tests -v"]
